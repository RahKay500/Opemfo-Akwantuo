generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MOTHER
  MIDWIFE
  DOCTOR
}

enum FacilityType {
  CHPS
  DISTRICT_HOSPITAL
  TEACHING_HOSPITAL
}

enum VisitType {
  ANTENATAL
  POSTNATAL
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ReferralStatus {
  SENT
  ACKNOWLEDGED
  PATIENT_ARRIVED
  COMPLETED
  CANCELLED
}

enum SymptomSeverity {
  MILD
  MODERATE
  SEVERE
}

enum AppointmentRequestType {
  ROUTINE
  GYNAECOLOGIST
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  DECLINED
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  passwordHash String?
  role         Role
  facilityId   String?
  facility     Facility? @relation(fields: [facilityId], references: [id])
  isActive     Boolean  @default(true)
  otp          String?
  otpExpiry    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient                Patient?              @relation("MotherAccount")
  registeredPatients      Patient[]             @relation("RegisteredBy")
  visitsAsNurse           Visit[]               @relation("NurseVisits")
  referralsInitiated      Referral[]            @relation("ReferralInitiator")
  referralSharesGiven     ReferralShare[]       @relation("SharedByNurse")
  referralSharesReceived  ReferralShare[]       @relation("SharedWithDoctor")
  symptomsReported        Symptom[]             @relation("SymptomReporter")
  symptomsReviewed        Symptom[]             @relation("SymptomReviewer")
  emergencyAlertsResolved EmergencyAlert[]      @relation("EmergencyResolver")
  notifications           Notification[]
  auditLogs               AuditLog[]

  @@index([facilityId])
}

model Facility {
  id        String       @id @default(cuid())
  name      String
  type      FacilityType
  region    String
  district  String
  phone     String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  users                User[]
  patients             Patient[]
  referralsFrom        Referral[] @relation("ReferralFromFacility")
  referralsTo          Referral[] @relation("ReferralToFacility")
}

model Patient {
  id                        String    @id @default(cuid())
  name                      String
  phone                     String
  dateOfBirth               DateTime
  ghanaCardId               String?
  facilityId                String
  facility                  Facility  @relation(fields: [facilityId], references: [id])
  registeredById            String
  registeredBy              User      @relation("RegisteredBy", fields: [registeredById], references: [id])
  userId                    String?   @unique
  user                      User?     @relation("MotherAccount", fields: [userId], references: [id])
  bloodGroup                String?
  gravida                   Int?
  para                      Int?
  lmp                       DateTime?
  edd                       DateTime?
  knownConditions           String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  emergencyContactRelation  String?
  deliveryDate              DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  visits              Visit[]
  referrals           Referral[]
  referralShares      ReferralShare[]
  symptoms            Symptom[]
  appointmentRequests AppointmentRequest[]
  emergencyAlerts     EmergencyAlert[]

  @@index([facilityId])
}

model Visit {
  id               String    @id @default(cuid())
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id])
  nurseId          String
  nurse            User      @relation("NurseVisits", fields: [nurseId], references: [id])
  visitType        VisitType
  gestationalAge   Int?
  daysPostpartum   Int?
  systolic         Int?
  diastolic        Int?
  fetalHeartRate   Int?
  temperature      Float?
  weight           Float?
  fundalHeight     Float?
  observations     String?
  flagged          Boolean   @default(false)
  flagReason       String?
  flagPriority     Priority?
  createdAt        DateTime  @default(now())

  @@index([patientId])
  @@index([nurseId])
}

model Referral {
  id                       String         @id @default(cuid())
  patientId                String
  patient                  Patient        @relation(fields: [patientId], references: [id])
  fromFacilityId           String
  fromFacility             Facility       @relation("ReferralFromFacility", fields: [fromFacilityId], references: [id])
  toFacilityId             String
  toFacility               Facility       @relation("ReferralToFacility", fields: [toFacilityId], references: [id])
  initiatedById            String
  initiatedBy              User           @relation("ReferralInitiator", fields: [initiatedById], references: [id])
  priority                 Priority
  systemSuggestedPriority  Priority
  nurseOverrideReason      String?
  reason                   String
  additionalNotes          String?
  transportMethod          String?
  includeHistory           Boolean        @default(true)
  includeVitals            Boolean        @default(true)
  includeFlags             Boolean        @default(true)
  status                   ReferralStatus @default(SENT)
  sentAt                   DateTime       @default(now())
  acknowledgedAt           DateTime?
  arrivedAt                DateTime?
  completedAt              DateTime?
  outcomeNotes             String?

  shares ReferralShare[]

  @@index([patientId])
  @@index([fromFacilityId])
  @@index([toFacilityId])
  @@index([status])
}

model ReferralShare {
  id                  String    @id @default(cuid())
  referralId          String?
  referral            Referral? @relation(fields: [referralId], references: [id])
  patientId           String?
  patient             Patient?  @relation(fields: [patientId], references: [id])
  sharedByNurseId     String
  sharedByNurse       User      @relation("SharedByNurse", fields: [sharedByNurseId], references: [id])
  sharedWithDoctorId  String
  sharedWithDoctor    User      @relation("SharedWithDoctor", fields: [sharedWithDoctorId], references: [id])
  reason              String?
  expiresAt           DateTime
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())

  @@index([referralId])
  @@index([patientId])
  @@index([sharedWithDoctorId])
}

model Symptom {
  id               String          @id @default(cuid())
  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id])
  reportedById     String
  reportedBy       User            @relation("SymptomReporter", fields: [reportedById], references: [id])
  symptoms         Json
  severity         SymptomSeverity
  notes            String?
  startedWhen      String?
  createdAt        DateTime        @default(now())
  reviewedByNurseId String?
  reviewedByNurse  User?           @relation("SymptomReviewer", fields: [reviewedByNurseId], references: [id])

  @@index([patientId])
}

model AppointmentRequest {
  id             String                 @id @default(cuid())
  patientId      String
  patient        Patient                @relation(fields: [patientId], references: [id])
  requestType    AppointmentRequestType
  preferredDate  DateTime
  preferredTime  String?
  reason         String?
  urgency        String?
  notes          String?
  status         AppointmentStatus      @default(PENDING)
  createdAt      DateTime               @default(now())

  @@index([patientId])
}

model EmergencyAlert {
  id           String    @id @default(cuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id])
  triggeredAt  DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("EmergencyResolver", fields: [resolvedById], references: [id])
  notes        String?
  isActive     Boolean   @default(true)

  @@index([patientId])
  @@index([isActive])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  relatedId   String?
  relatedType String?

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  ipAddress  String?

  @@index([actorId])
  @@index([entityType, entityId])
}
