generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MOTHER
  MIDWIFE
  DOCTOR
}

enum FacilityType {
  CHPS
  DISTRICT_HOSPITAL
  TEACHING_HOSPITAL
}

enum VisitType {
  ANTENATAL
  POSTNATAL
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ReferralStatus {
  SENT
  ACKNOWLEDGED
  PATIENT_ARRIVED
  COMPLETED
  CANCELLED
}

enum SymptomSeverity {
  MILD
  MODERATE
  SEVERE
}

enum AppointmentRequestType {
  ROUTINE
  GYNAECOLOGIST
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  DECLINED
}

// Ghana MCH Record Book's Antenatal/Postnatal Follow-Up table notation:
// negative (－), or positive by degree (+/++/+++).
enum UrineTestResult {
  NEGATIVE
  TRACE
  PLUS_1
  PLUS_2
  PLUS_3
}

enum FetalPresentation {
  CEPHALIC
  BREECH
  OTHER
}

// PNC1 (24-48hrs) / PNC2 (6th-7th day) / PNC3 (at 6 weeks) per the MCH
// Record Book's postnatal visit schedule.
enum PostnatalVisitType {
  PNC1
  PNC2
  PNC3
}

model User {
  id            String    @id @default(cuid())
  name          String
  phone         String    @unique
  passwordHash  String?
  role          Role
  facilityId    String?
  facility      Facility? @relation(fields: [facilityId], references: [id])
  isActive      Boolean   @default(true)
  otp           String?
  otpExpiry     DateTime?
  // Professional licence number, captured at provisioning time by the Super
  // Admin portal. Not verified against any registry yet — stored for a
  // future verification step.
  licenseNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient                 Patient?         @relation("MotherAccount")
  registeredPatients      Patient[]        @relation("RegisteredBy")
  visitsAsNurse           Visit[]          @relation("NurseVisits")
  referralsInitiated      Referral[]       @relation("ReferralInitiator")
  referralSharesGiven     ReferralShare[]  @relation("SharedByNurse")
  referralSharesReceived  ReferralShare[]  @relation("SharedWithDoctor")
  symptomsReported        Symptom[]        @relation("SymptomReporter")
  symptomsReviewed        Symptom[]        @relation("SymptomReviewer")
  emergencyAlertsResolved EmergencyAlert[] @relation("EmergencyResolver")
  notifications           Notification[]
  auditLogs               AuditLog[]
  deliveryRecordsRecorded DeliveryRecord[] @relation("DeliveryRecordedBy")
  postnatalVisitsAsNurse  PostnatalVisit[] @relation("PostnatalVisitNurse")

  @@index([facilityId])
}

model Facility {
  id        String       @id @default(cuid())
  name      String
  type      FacilityType
  region    String
  district  String
  phone     String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  users         User[]
  patients      Patient[]
  referralsFrom Referral[]   @relation("ReferralFromFacility")
  referralsTo   Referral[]   @relation("ReferralToFacility")
  admins        SuperAdmin[]
}

model Patient {
  id                       String    @id @default(cuid())
  name                     String
  phone                    String
  dateOfBirth              DateTime
  ghanaCardId              String?
  facilityId               String
  facility                 Facility  @relation(fields: [facilityId], references: [id])
  registeredById           String
  registeredBy             User      @relation("RegisteredBy", fields: [registeredById], references: [id])
  userId                   String?   @unique
  user                     User?     @relation("MotherAccount", fields: [userId], references: [id])
  bloodGroup               String?
  gravida                  Int?
  para                     Int?
  lmp                      DateTime?
  edd                      DateTime?
  knownConditions          String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  deliveryDate             DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Ghana MCH Record Book — Family Identification (page 3)
  nhisNumber              String?
  maritalStatus           String?
  educationalLevel        String?
  occupation              String?
  spouseName              String?
  spousePhone             String?
  spouseOccupation        String?
  emergencyTransportPhone String?

  // Obstetric History (page 4) — no. of pregnancies/births already covered
  // by gravida/para above; the document splits abortions into these two.
  numberOfAbortionsSpontaneous Int?
  numberOfAbortionsInduced     Int?
  // Array of {dateOfDeliveryOrLoss, placeOfBirth, problemsDuringPregnancy,
  // gestationalAgeAtBirth, modeOfDelivery, outcome, complications, childSex,
  // birthWeightKg, childPresentHealth}, one entry per prior pregnancy.
  previousPregnancies Json?
  // Free-form values from the document's risk-factor list (e.g. "Previous CS",
  // "Grand multiparty", "Previous PPH", "Previous PIH", "Myomectomy", "Sickle
  // cell disease").
  majorRiskFactors    String[]

  // Medical/Surgical/Social/Family History (page 5-6)
  medicalHistory Json? // {hypertension, heartDisease, sickleCellDisease, diabetes, epilepsy, asthma, allergiesDrugFood, medicationHistory, hivInfection, previousSurgery, other}
  socialHistory  Json? // {alcohol, smoking}
  familyHistory  Json? // {hypertension, heartDisease, sickleCellDisease, diabetes, multiplePregnancies, birthDefects, mentalHealthDisorder, other}

  // Investigations (page 6) — bloodGroup already exists above.
  rhTyping String?
  hbsAg    String?
  sickling String?
  g6pd     String?
  vdrl     String?
  hivStatus String?

  height                      Float?
  weightAtAnc1                Float?
  bmiAtAnc1                   Float?
  // Document expresses this as a range (e.g. "66.5-71kg"), not a single value.
  estimatedDesiredWeightAtEdd String?
  contraceptionUsed           String?

  visits              Visit[]
  referrals           Referral[]
  referralShares      ReferralShare[]
  symptoms            Symptom[]
  appointmentRequests AppointmentRequest[]
  emergencyAlerts     EmergencyAlert[]
  partnerLinks        PartnerLink[]
  vaccinations        Vaccination[]
  iptpDoses           IptpDose[]
  deliveryRecord      DeliveryRecord?
  postnatalVisits     PostnatalVisit[]
  labResults          LabResult[]

  @@index([facilityId])
}

// A shareable, revocable read-only link a mother can hand to her partner —
// deliberately not a full account (no login, no Role) since a partner isn't
// clinical staff and doesn't need a persistent identity. Only one row per
// patient should have revokedAt: null at a time; generating a new link
// revokes the previous one instead of allowing several simultaneously.
model PartnerLink {
  id           String    @id @default(cuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id])
  token        String    @unique
  partnerName  String?
  partnerPhone String?
  // Per-category visibility, set by the mother when the invite is created.
  // Defaults mirror the Figma spec: everyday pregnancy info is shared by
  // default, more sensitive clinical detail (referral status, medical
  // history) is opt-in.
  shareProgress       Boolean   @default(true)
  shareAppointments   Boolean   @default(true)
  shareVitals         Boolean   @default(true)
  shareVisitSummaries Boolean   @default(true)
  shareReferralStatus Boolean   @default(false)
  shareMedicalHistory Boolean   @default(false)
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@index([patientId])
}

model Visit {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id])
  nurseId        String
  nurse          User      @relation("NurseVisits", fields: [nurseId], references: [id])
  visitType      VisitType
  gestationalAge Int?
  daysPostpartum Int?
  systolic       Int?
  diastolic      Int?
  fetalHeartRate Int?
  temperature    Float?
  weight         Float?
  fundalHeight   Float?
  observations   String?
  flagged        Boolean   @default(false)
  flagReason     String?
  flagPriority   Priority?
  createdAt      DateTime  @default(now())

  // Remaining Antenatal Follow-Up table columns (page 7) not already covered
  // by the fields above.
  urineProt         UrineTestResult?
  urineSugar        UrineTestResult?
  oedema            Boolean?
  fetalPresentation FetalPresentation?
  // Document uses fraction notation like "4/5th" — free text, not numeric.
  fetalDescent      String?
  ifaSupplied       Int?
  complaints        String?

  @@index([patientId])
  @@index([nurseId])
}

model Referral {
  id                      String         @id @default(cuid())
  patientId               String
  patient                 Patient        @relation(fields: [patientId], references: [id])
  fromFacilityId          String
  fromFacility            Facility       @relation("ReferralFromFacility", fields: [fromFacilityId], references: [id])
  toFacilityId            String
  toFacility              Facility       @relation("ReferralToFacility", fields: [toFacilityId], references: [id])
  initiatedById           String
  initiatedBy             User           @relation("ReferralInitiator", fields: [initiatedById], references: [id])
  priority                Priority
  systemSuggestedPriority Priority
  nurseOverrideReason     String?
  reason                  String
  additionalNotes         String?
  transportMethod         String?
  includeHistory          Boolean        @default(true)
  includeVitals           Boolean        @default(true)
  includeFlags            Boolean        @default(true)
  status                  ReferralStatus @default(SENT)
  sentAt                  DateTime       @default(now())
  acknowledgedAt          DateTime?
  arrivedAt               DateTime?
  completedAt             DateTime?
  outcomeNotes            String?

  shares ReferralShare[]

  @@index([patientId])
  @@index([fromFacilityId])
  @@index([toFacilityId])
  @@index([status])
}

model ReferralShare {
  id                 String    @id @default(cuid())
  referralId         String?
  referral           Referral? @relation(fields: [referralId], references: [id])
  patientId          String?
  patient            Patient?  @relation(fields: [patientId], references: [id])
  sharedByNurseId    String
  sharedByNurse      User      @relation("SharedByNurse", fields: [sharedByNurseId], references: [id])
  sharedWithDoctorId String
  sharedWithDoctor   User      @relation("SharedWithDoctor", fields: [sharedWithDoctorId], references: [id])
  reason             String?
  expiresAt          DateTime
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())

  @@index([referralId])
  @@index([patientId])
  @@index([sharedWithDoctorId])
}

model Symptom {
  id                String          @id @default(cuid())
  patientId         String
  patient           Patient         @relation(fields: [patientId], references: [id])
  reportedById      String
  reportedBy        User            @relation("SymptomReporter", fields: [reportedById], references: [id])
  symptoms          Json
  severity          SymptomSeverity
  notes             String?
  startedWhen       String?
  createdAt         DateTime        @default(now())
  reviewedByNurseId String?
  reviewedByNurse   User?           @relation("SymptomReviewer", fields: [reviewedByNurseId], references: [id])

  @@index([patientId])
}

model AppointmentRequest {
  id            String                 @id @default(cuid())
  patientId     String
  patient       Patient                @relation(fields: [patientId], references: [id])
  requestType   AppointmentRequestType
  preferredDate DateTime
  preferredTime String?
  reason        String?
  urgency       String?
  notes         String?
  status        AppointmentStatus      @default(PENDING)
  createdAt     DateTime               @default(now())

  @@index([patientId])
}

model EmergencyAlert {
  id           String    @id @default(cuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id])
  triggeredAt  DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("EmergencyResolver", fields: [resolvedById], references: [id])
  notes        String?
  isActive     Boolean   @default(true)

  @@index([patientId])
  @@index([isActive])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  relatedId   String?
  relatedType String?

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  // Set instead of actorId for actions with no User row — e.g. the Super
  // Admin portal, whose accounts live in the separate SuperAdmin model, not
  // here, since they aren't a MOTHER/MIDWIFE/DOCTOR.
  actorLabel String?
  // Set only for facility-scoped admin actions (staff created/updated/
  // deactivated/OTP-resent) so a Facility Admin's audit view can filter to
  // just their own facility. Platform-level actions (facility created, admin
  // login/password changes, facility-admin created) leave this null.
  facilityId String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  ipAddress  String?

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([facilityId])
}

// Deliberately separate from User — Super Admins aren't a MOTHER, MIDWIFE, or
// DOCTOR and shouldn't be reachable through any role-based query on that
// table. Two tiers share this one model: facilityId null is the Platform
// Super Admin (bootstrapped once from SUPER_ADMIN_PHONE/SUPER_ADMIN_PASSWORD
// env vars — see lib/admin-auth.ts — manages the facility list and creates
// Facility Admin accounts); facilityId set is a Facility Admin, scoped to
// managing only that facility's staff, created by the Platform Super Admin
// and activated via OTP + set-password exactly like staff (isActive/
// passwordHash null until then).
model SuperAdmin {
  id                  String    @id @default(cuid())
  phone               String    @unique
  passwordHash        String?
  facilityId          String?
  facility            Facility? @relation(fields: [facilityId], references: [id])
  isActive            Boolean   @default(true)
  // A password change only takes effect once the OTP sent to this admin's
  // own phone is confirmed — otherwise a hijacked-but-unlocked session could
  // silently lock the real admin out with no recovery path.
  pendingPasswordHash String?
  otp                 String?
  otpExpiry           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([facilityId])
}

// Ghana MCH Record Book, Tetanus-diphtheria Immunization Schedule (page 8).
// type is free text (e.g. "TD") rather than an enum so a future vaccine type
// doesn't need a migration.
model Vaccination {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  type           String
  doseNumber     Int
  dateGiven      DateTime
  batchNumber    String?
  gestationalAge Int?
  createdAt      DateTime @default(now())

  @@index([patientId])
}

// Intermittent Preventive Treatment for malaria in pregnancy (page 8) — kept
// separate from Vaccination since IPTp is antimalarial chemoprevention, not
// a vaccine, matching how the record book itself separates the two tables.
model IptpDose {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  doseNumber     Int
  dateGiven      DateTime
  gestationalAge Int?
  createdAt      DateTime @default(now())

  @@index([patientId])
}

// Delivery Outcome + Mother's Condition at Discharge (page 21).
model DeliveryRecord {
  id           String  @id @default(cuid())
  patientId    String  @unique
  patient      Patient @relation(fields: [patientId], references: [id])
  recordedById String
  recordedBy   User    @relation("DeliveryRecordedBy", fields: [recordedById], references: [id])

  weeksOfPregnancy      Int?
  dateOfDelivery        DateTime?
  timeOfDelivery        String?
  timeOfPlacentaDelivery String?
  durationOfLabourHours   Int?
  durationOfLabourMinutes Int?
  // Normal / Vacuum / Caesarean Section / Other
  typeOfDelivery          String?
  indicationForVacuumOrCs String?
  anesthesia              String?
  estimatedBloodLossMl    Int?
  bloodTransfusion        Boolean?
  statePlacentaMembranes  String?
  manualRemovalOfPlacenta Boolean?
  // Intact / Tear / Episiotomy
  statePerineum               String?
  labourDeliveryComplications String?
  birthAttendant               String?
  placeOfDelivery               String?
  breastfedWithin30Min           Boolean?
  skinToSkinContact               Boolean?
  babySex                          String?
  babyBirthWeightKg                Float?
  babyCondition                     String?
  createdAt                         DateTime @default(now())

  @@index([patientId])
}

// Postnatal Follow-Up (page 23) — PNC1 (24-48hrs) / PNC2 (6th-7th day) /
// PNC3 (6 weeks) per the record book's postnatal visit schedule.
model PostnatalVisit {
  id        String             @id @default(cuid())
  patientId String
  patient   Patient            @relation(fields: [patientId], references: [id])
  nurseId   String
  nurse     User               @relation("PostnatalVisitNurse", fields: [nurseId], references: [id])
  visitType PostnatalVisitType

  dateOfVisit             DateTime
  weight                  Float?
  systolic                Int?
  diastolic               Int?
  pulse                   Int?
  temperature             Float?
  urineProt               UrineTestResult?
  urineSugar              UrineTestResult?
  fundalHeight            Float?
  lochiaColour            String?
  lochiaOdour             String?
  incisionPerineumCs      String?
  conditionOfBreastNipple String?
  moodChanges             String?
  ifaSupplied             Int?
  complaints              String?
  createdAt               DateTime @default(now())

  @@index([patientId])
}

// Investigation for Mother after Delivery (page 23) and any other ad-hoc lab
// work not already covered by Patient's own investigation fields.
model LabResult {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  testType   String
  dateGiven  DateTime
  result     String
  isAbnormal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([patientId])
}
